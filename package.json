    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tsx": "^4.21.0",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^0.21.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
